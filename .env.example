APP_ENV=production
APP_NAME=YouTube Clipper API
APP_VERSION=1.0.0

# MongoDB and Redis
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
REDIS_URL=rediss://default:<password>@<host>:<port>

# DigitalOcean Spaces (S3-compatible)
SPACES_BUCKET=your-space-name
SPACES_ACCESS_KEY=your-digitalocean-spaces-access-key
SPACES_SECRET_KEY=your-digitalocean-spaces-secret-key
SPACES_REGION=sgp1
SPACES_ENDPOINT=https://sgp1.digitaloceanspaces.com
SIGNED_URL_TTL_SECONDS=3600

# Frontend and API
ALLOWED_ORIGINS=https://your-frontend-domain
API_BASE_URL=https://your-backend-domain/api/v1
